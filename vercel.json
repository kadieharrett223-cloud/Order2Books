{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "migrations/**"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/webhooks/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/eula.html",
      "dest": "/frontend/eula.html"
    },
    {
      "src": "/privacy-policy.html",
      "dest": "/frontend/privacy-policy.html"
    },
    {
      "src": "/ops-review-2026.html",
      "dest": "/frontend/ops-review-2026.html"
    },
    {
      "src": "/merchant-walkthrough-video.mp4",
      "dest": "/frontend/merchant-walkthrough-video.mp4"
    },
    {
      "src": "/vite.svg",
      "dest": "/frontend/vite.svg"
    },
    {
      "src": "/order2books-logo.svg",
      "dest": "/frontend/order2books-logo.svg"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/vite.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
